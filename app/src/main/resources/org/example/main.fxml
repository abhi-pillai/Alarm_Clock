<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.MainController"
      spacing="16"
      styleClass="root-container"
      stylesheets="@style.css">

    <Label fx:id="clockLabel"
           text="00:00:00"
           styleClass="clock-label"/>

    <Separator/>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="timeField"
                   promptText="HH:MM"
                   prefWidth="80"
                   styleClass="time-field"/>
        <TextField fx:id="labelField"
                   promptText="Label (optional)"
                   HBox.hgrow="ALWAYS"/>
        <CheckBox  fx:id="repeatCheck" text="Daily"/>
        <Button    text="Add" onAction="#handleAddAlarm"
                   styleClass="add-button"/>
    </HBox>

    <ListView fx:id="alarmListView" prefHeight="200" styleClass="alarm-list">
        <placeholder>
            <Label text="No alarms set yet" styleClass="placeholder-label"/>
        </placeholder>
    </ListView>

    <Button text="Delete Selected"
            onAction="#handleDeleteAlarm"
            styleClass="delete-button"/>

    <Label fx:id="statusLabel" text="" styleClass="status-label"/>

</VBox>