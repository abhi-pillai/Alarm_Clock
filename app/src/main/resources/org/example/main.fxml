<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.MainController"
      spacing="16"
      style="-fx-padding: 24; -fx-min-width: 400;">

    <Label fx:id="clockLabel"
           text="00:00:00"
           style="-fx-font-size: 48px; -fx-font-family: monospace;
                  -fx-alignment: center; -fx-max-width: infinity;"/>

    <Separator/>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="timeField"
                   promptText="HH:MM"
                   prefWidth="80"
                   style="-fx-font-family: monospace;"/>
        <TextField fx:id="labelField"
                   promptText="Label (optional)"
                   HBox.hgrow="ALWAYS"/>
        <Button text="Add Alarm" onAction="#handleAddAlarm"/>
    </HBox>

    <ListView fx:id="alarmListView" prefHeight="220">
        <placeholder>
            <Label text="No alarms set yet"/>
        </placeholder>
    </ListView>

    <Button text="Delete Selected"
            onAction="#handleDeleteAlarm"
            style="-fx-max-width: infinity;"/>

    <!-- Shows which alarm just fired -->
    <Label fx:id="statusLabel"
           text=""
           style="-fx-font-size: 13px; -fx-text-fill: gray;
                  -fx-alignment: center; -fx-max-width: infinity;"/>

</VBox>