<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.fxml.FXMLLoader?>

<TabPane xmlns:fx="http://javafx.com/fxml"
         fx:controller="org.example.MainController"
         stylesheets="@style.css"
         tabClosingPolicy="UNAVAILABLE"
         styleClass="root-tab-pane">

    <tabs>
        <Tab text="🕐  Clock">
            <content>
                <fx:include source="clock.fxml"/>
            </content>
        </Tab>
        <Tab text="⏰  Alarm">
            <content>
                <fx:include source="alarm.fxml"/>
            </content>
        </Tab>
        <Tab text="⏱  Timer">
            <content>
                <fx:include source="timer.fxml"/>
            </content>
        </Tab>
    </tabs>

</TabPane>