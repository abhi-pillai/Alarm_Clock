<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.ClockController"
      alignment="CENTER"
      spacing="12"
      styleClass="tab-content">

    <!-- Digital time -->
    <Label fx:id="digitalLabel"
           text="10:24 AM"
           styleClass="clock-label"/>

    <!-- Date and timezone -->
    <Label fx:id="dateLabel"
           text="Wednesday, 27 May"
           styleClass="date-label"/>

    <Label fx:id="tzLabel"
           text="IST · UTC+5:30"
           styleClass="tz-label"/>

    <!-- Analog clock face -->
    <Canvas fx:id="clockCanvas" width="220" height="220"/>

    <!-- 12hr / 24hr pill toggle -->
    <HBox alignment="CENTER" spacing="0">
        <ToggleButton fx:id="formatToggle"
                      text="Switch to 24hr"
                      onAction="#handleFormatToggle"
                      styleClass="format-toggle"/>
    </HBox>

</VBox>