<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.AlarmController"
      spacing="0"
      styleClass="alarm-root"
      stylesheets="@style.css">

    <!-- Top bar -->
    <HBox styleClass="alarm-topbar" alignment="CENTER_LEFT">
        <Label text="Alarms" styleClass="alarm-topbar-title"
               HBox.hgrow="ALWAYS"/>
        <Button text="+" onAction="#handleAddAlarm"
                styleClass="alarm-add-fab"/>
    </HBox>

    <!-- Alarm list -->
    <ListView fx:id="alarmListView"
              VBox.vgrow="ALWAYS"
              styleClass="alarm-main-list">
        <placeholder>
            <VBox alignment="CENTER" spacing="10"
                  style="-fx-padding:60px 20px;">
                <Label text="No alarms yet"
                       styleClass="empty-title"/>
                <Label text="Tap + to add your first alarm"
                       styleClass="empty-hint"/>
            </VBox>
        </placeholder>
    </ListView>

    <Label fx:id="statusLabel" text=""
           styleClass="status-label"
           style="-fx-padding:6px 16px;"/>

</VBox>