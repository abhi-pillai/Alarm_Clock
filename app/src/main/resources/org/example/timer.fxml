<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.Canvas?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.TimerController"
      spacing="0"
      styleClass="tab-content"
      style="-fx-padding: 16px 14px;">

    <!-- ── Presets row ── -->
    <Label text="PRESETS" styleClass="section-title"
           style="-fx-padding: 0 0 8px 0;"/>

    <HBox fx:id="presetsRow" spacing="8"
          alignment="CENTER_LEFT"
          style="-fx-padding: 0 0 16px 0;">

        <!-- Default presets — built at runtime in controller -->
        <!-- + button to add custom -->
        <Button text="+" onAction="#handleAddPreset"
                styleClass="add-preset-btn"
                prefWidth="64" prefHeight="64"/>

    </HBox>

    <!-- ── Progress ring ── -->
    <HBox alignment="CENTER"
          style="-fx-padding: 4px 0 16px 0;">
        <Canvas fx:id="progressCanvas" width="190" height="190"/>
    </HBox>

    <!-- ── Controls ── -->
    <HBox alignment="CENTER" spacing="14"
          style="-fx-padding: 0 0 16px 0;">

        <Button text="↺  Reset"
                onAction="#handleReset"
                styleClass="timer-ctrl-btn"/>

        <Button fx:id="startPauseBtn"
                text="▶"
                onAction="#handleStartPause"
                styleClass="timer-play-btn"/>

        <Button text="■  Stop"
                onAction="#handleStop"
                styleClass="timer-stop-btn"/>

    </HBox>

    <!-- ── Sound row ── -->
    <VBox styleClass="timer-sound-card" spacing="0">
        <HBox styleClass="option-row" alignment="CENTER_LEFT">
            <Label text="Sound" styleClass="option-label"
                HBox.hgrow="ALWAYS"/>
            <Label fx:id="selectedTuneLabel" text="Default beep"
                styleClass="option-hint"/>
            <Button text="›" onAction="#handleOpenSoundPicker"
                    styleClass="option-chevron"/>
        </HBox>
    </VBox>

    <!-- ── Status ── -->
    <Label fx:id="timerStatusLabel" text=""
           styleClass="status-label"
           style="-fx-padding: 8px 0 0 0;"/>

</VBox>