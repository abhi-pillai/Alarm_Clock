<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.Canvas?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.TimerController"
      alignment="CENTER"
      spacing="16"
      styleClass="tab-content">

    <!-- Progress ring with time inside -->
    <Canvas fx:id="progressCanvas" width="200" height="200"/>

    <!-- Adjustment buttons -->
    <HBox spacing="8" alignment="CENTER">
        <Button text="− 1m"  onAction="#handleMinusMin"
                styleClass="timer-adj-button"/>
        <Button text="− 10s" onAction="#handleMinusSec"
                styleClass="timer-adj-button"/>
        <Button text="+ 10s" onAction="#handlePlusSec"
                styleClass="timer-adj-button"/>
        <Button text="+ 1m"  onAction="#handlePlusMin"
                styleClass="timer-adj-button"/>
    </HBox>

    <!-- Start/Pause and Reset -->
    <HBox spacing="12" alignment="CENTER">
        <Button fx:id="startPauseBtn"
                text="Start"
                onAction="#handleStartPause"
                styleClass="add-button"
                prefWidth="120"/>
        <Button text="Reset"
                onAction="#handleReset"
                styleClass="delete-button"
                prefWidth="100"/>
    </HBox>

    <!-- Sound row — opens popup -->
    <VBox styleClass="timer-sound-card" spacing="0">
        <HBox styleClass="option-row" alignment="CENTER_LEFT">
            <Label text="Sound" styleClass="option-label"
                   HBox.hgrow="ALWAYS"/>
            <Label fx:id="selectedTuneLabel"
                   text="Default beep"
                   styleClass="option-hint"/>
            <Button text="›"
                    onAction="#handleOpenSoundPicker"
                    styleClass="option-chevron"/>
        </HBox>
    </VBox>

    <Label fx:id="timerStatusLabel" text=""
           styleClass="status-label"/>

</VBox>