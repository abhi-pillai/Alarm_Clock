<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.layout.StackPane?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.AlarmSetterController"
      spacing="0"
      stylesheets="@style.css"
      styleClass="setter-root"
      minWidth="420" maxWidth="420">

    <!-- Header -->
    <HBox styleClass="setter-header" alignment="CENTER_LEFT">
        <Label text="Set alarm" styleClass="setter-title"/>
    </HBox>

    <!-- Picker area -->
    <HBox spacing="16" alignment="TOP_CENTER"
          styleClass="setter-picker-row">

        <!-- Left: digital + AM/PM + mode toggle -->
        <VBox spacing="10" alignment="CENTER" minWidth="140">

            <HBox spacing="6" alignment="CENTER">
                <Label fx:id="hourDisplay" text="07"
                       styleClass="time-display time-display-active"
                       onMouseClicked="#handleHourClick"/>
                <Label text=":" styleClass="time-colon"/>
                <Label fx:id="minuteDisplay" text="30"
                       styleClass="time-display"
                       onMouseClicked="#handleMinuteClick"/>
            </HBox>

            <HBox styleClass="ampm-group" alignment="CENTER">
                <ToggleButton fx:id="amBtn" text="AM"
                              styleClass="ampm-btn"
                              onAction="#handleAmPm"/>
                <ToggleButton fx:id="pmBtn" text="PM"
                              styleClass="ampm-btn"
                              onAction="#handleAmPm"/>
            </HBox>

            <Button fx:id="modeToggleBtn" text="⌨"
                    onAction="#handleModeToggle"
                    styleClass="mode-btn"/>
        </VBox>

        <!-- Right: dial or drum -->
        <StackPane HBox.hgrow="ALWAYS"
                   minWidth="210" minHeight="210">
            <Canvas fx:id="dialCanvas" width="210" height="210"
                    onMousePressed="#handleDialPress"
                    onMouseDragged="#handleDialDrag"/>
            <HBox fx:id="drumBox" spacing="4" alignment="CENTER"
                  visible="false" managed="false"
                  styleClass="drum-box">
                <ListView fx:id="hourDrum" prefWidth="95"
                          styleClass="drum-list"/>
                <ListView fx:id="minuteDrum" prefWidth="95"
                          styleClass="drum-list"/>
            </HBox>
        </StackPane>

    </HBox>

    <!-- Options -->
    <VBox styleClass="setter-options" spacing="0">

        <HBox styleClass="option-row" alignment="CENTER_LEFT">
            <Label text="Repeat" styleClass="option-label"
                   HBox.hgrow="ALWAYS"/>
            <CheckBox fx:id="repeatCheck" styleClass="repeat-check"/>
            <Label text="Daily" styleClass="option-hint"
                   style="-fx-padding:0 0 0 6px;"/>
        </HBox>
        <Separator styleClass="option-sep"/>

        <HBox styleClass="option-row" alignment="CENTER_LEFT" spacing="12">
            <Label text="Label" styleClass="option-label"/>
            <TextField fx:id="labelField"
                       promptText="e.g. Wake up"
                       HBox.hgrow="ALWAYS"
                       styleClass="label-field"/>
        </HBox>
        <Separator styleClass="option-sep"/>

        <HBox styleClass="option-row" alignment="CENTER_LEFT">
            <Label text="Sound" styleClass="option-label"
                   HBox.hgrow="ALWAYS"/>
            <Label fx:id="selectedTuneLabel" text="Default beep"
                   styleClass="option-hint"/>
            <Button text="›" onAction="#handleOpenSoundPicker"
                    styleClass="option-chevron"/>
        </HBox>
        <Separator styleClass="option-sep"/>

        <HBox styleClass="option-row" alignment="CENTER_LEFT">
            <Label text="Snooze" styleClass="option-label"
                   HBox.hgrow="ALWAYS"/>
            <ToggleButton fx:id="snoozeToggle"
                          styleClass="ios-toggle"
                          onAction="#handleSnoozeToggle"/>
        </HBox>

    </VBox>

    <!-- Actions -->
    <HBox styleClass="setter-actions" alignment="CENTER_RIGHT" spacing="10">
        <Button text="Cancel" onAction="#handleCancel"
                styleClass="action-cancel"/>
        <Button text="Save alarm" onAction="#handleSave"
                styleClass="action-ok"/>
    </HBox>

</VBox>